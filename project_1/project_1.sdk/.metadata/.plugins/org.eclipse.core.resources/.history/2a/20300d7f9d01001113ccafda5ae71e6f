static inline float clampf(float x, float lo, float hi) {
    if (x < lo) return lo;
    if (x > hi) return hi;
    return x;
}

// exp approximation (used when USE_MATH_H=0)
static inline float expf_approx(float x) {
#if USE_MATH_H
    return expf(x);
#else
    // Clamp to avoid overflow
    x = clampf(x, -80.0f, 80.0f);

    // e^x = 2^(x / ln2)
    const float inv_ln2 = 1.44269504088896341f; // 1/ln(2)
    const float ln2     = 0.6931471805599453f;

    float y = x * inv_ln2;
    int n = (int)(y);
    float f = y - (float)n;


    float p = 1.0f
            + f * ln2
            + (f*f) * (ln2*ln2*0.5f)
            + (f*f*f) * (ln2*ln2*ln2*(1.0f/6.0f));

    // scale by 2^n using exponent bits
    int exp = n + 127;
    if (exp <= 0) return 0.0f;
    if (exp >= 255) return 3.402823466e+38f; // FLT_MAX
    union { uint32_t i; float f; } u;
    u.i = (uint32_t)(exp << 23);
    return u.f * p;
#endif
}

static inline float sigmoidf(float x) {
    x = clampf(x, -20.0f, 20.0f);
#if USE_MATH_H
    return 1.0f / (1.0f + expf(-x));
#else
    float e = expf_approx(-x);
    return 1.0f / (1.0f + e);
#endif
}

static inline float tanhf_approx(float x) {
#if USE_MATH_H
    return tanhf(x);
#else
    // tanh(x) = 2*sigmoid(2x) - 1
    float s = sigmoidf(2.0f * x);
    return 2.0f * s - 1.0f;
#endif
}

static void softmax5(const float logits[NUM_CLASSES], float prob[NUM_CLASSES]) {
    float m = logits[0];
    for (int i = 1; i < NUM_CLASSES; ++i) if (logits[i] > m) m = logits[i];

    float sum = 0.0f;
    for (int i = 0; i < NUM_CLASSES; ++i) {
        float e = expf_approx(logits[i] - m);
        prob[i] = e;
        sum += e;
    }
    if (sum <= 0.0f) {
        for (int i = 0; i < NUM_CLASSES; ++i) prob[i] = 1.0f / (float)NUM_CLASSES;
        return;
    }
    float inv = 1.0f / sum;
    for (int i = 0; i < NUM_CLASSES; ++i) prob[i] *= inv;
}

static int argmax5(const float prob[NUM_CLASSES]) {
    int best = 0;
    float m = prob[0];
    for (int i = 1; i < NUM_CLASSES; ++i) {
        if (prob[i] > m) { m = prob[i]; best = i; }
    }
    return best;
}



